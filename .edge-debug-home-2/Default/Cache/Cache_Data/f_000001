  <!-- ════════════ SCRIPTS ════════════ -->
  <script src="js/database.js"></script>
  <script src="js/main.js"></script>
  <script src="js/effects.js"></script>

  <script>
    /* ── Widget de Contacto Flotante ────────────────────────── */
    (function () {
      const toggle = document.getElementById('contact-toggle');
      const menu = document.getElementById('contact-menu');
      if (!toggle || !menu) return;

      let isOpen = false;

      toggle.addEventListener('click', () => {
        isOpen = !isOpen;
        menu.classList.toggle('open', isOpen);
        toggle.setAttribute('aria-expanded', isOpen);

        // Rotar ícono cuando está abierto
        toggle.style.transform = isOpen ? 'rotate(45deg) scale(1.05)' : '';
      });

      // Cerrar al hacer clic fuera
      document.addEventListener('click', (e) => {
        if (isOpen && !toggle.contains(e.target) && !menu.contains(e.target)) {
          isOpen = false;
          menu.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.style.transform = '';
        }
      });
    })();

    /* ── Render Vinos Destacados ────────────────────────────── */
    function getHomepageFallbackWines() {
      return [
        {
          id: 'fallback-1',
          name: 'Vortex Nebula',
          vintage: 2019,
          description: 'Selección de portada mientras sincronizamos el inventario real de la bodega.',
          price: 189,
          discount: 0,
          stock: 12,
          featured: true,
          category: 'Vino Tinto',
          imageUrl: 'assets/images/wines/bottles-1.png',
          emoji: '🍷',
        },
        {
          id: 'fallback-2',
          name: 'Bifrost Aurora',
          vintage: 2021,
          description: 'Etiqueta destacada para mantener la colección visible en todos los dispositivos.',
          price: 142,
          discount: 0,
          stock: 9,
          featured: true,
          category: 'Vino Blanco',
          imageUrl: 'assets/images/wines/bottles-2.png',
          emoji: '🥂',
        },
        {
          id: 'fallback-3',
          name: 'Vortex Eclipse',
          vintage: 2020,
          description: 'Producto de relleno temporal hasta que entren los vinos más vendidos por ventas reales.',
          price: 245,
          discount: 10,
          stock: 7,
          featured: true,
          category: 'Vino Tinto',
          imageUrl: 'assets/images/wines/bottles-1.png',
          emoji: '🍾',
        }
      ];
    }

    function selectHomepageWines(allWines) {
      const inStock = (allWines || []).filter(wine => Number(wine.stock ?? 0) > 0);
      const featuredInStock = inStock.filter(wine => wine.featured);
      const nonFeaturedInStock = inStock.filter(wine => !wine.featured);
      const selected = [...featuredInStock, ...nonFeaturedInStock].slice(0, 3);

      if (selected.length >= 3) return selected;

      const usedIds = new Set(selected.map(wine => String(wine.id)));
      const fallbackExtras = getHomepageFallbackWines()
        .filter(wine => !usedIds.has(String(wine.id)))
        .slice(0, 3 - selected.length);

      const finalSelection = [...selected, ...fallbackExtras];
      return finalSelection.length ? finalSelection : getHomepageFallbackWines();
    }

    function buildHomepageWineCards(wines, settings) {
      const flashPct = settings.flashSaleActive ? (settings.flashSaleDiscount || 0) : 0;
      const driftDirs = ['left', 'right', 'left'];
      const driftAmt  = [50, 60, 50];

      return wines.map((wine, i) => {
        const itemPct    = wine.discount || 0;
        const discPct    = Math.max(flashPct, itemPct);
        const finalPrice = discPct > 0 ? wine.price * (1 - discPct / 100) : wine.price;
        const stockLevel = window.BifrostDB.constructor.stockLevel(wine.stock);
        const delays     = ['', 'reveal--delay-2', 'reveal--delay-4'];
        const floatCls   = ['float-3d-1', 'float-3d-2', 'float-3d-3'][i];
        const desc       = wine.description
          ? wine.description.substring(0, 110) + (wine.description.length > 110 ? '…' : '')
          : '';
        const icon = wine.imageUrl ? '' : (wine.emoji || '🍷');
        const imageSrc = window.getWineImageUrl(wine);
        const fallbackSrc = window.normalizeAssetUrl(window.getWineFallbackAsset(wine));
        const targetHref = String(wine.id).startsWith('fallback-')
          ? 'statics/shop.html'
          : `statics/product-detail.html?id=${wine.id}`;

        return `
          <article class="product-card reveal scale-in ${delays[i]} ${floatCls}"
                   data-drift="${driftDirs[i]}"
                   data-drift-intensity="${driftAmt[i]}"
                   onclick="window.location.href='${targetHref}'"
                   role="article"
                   aria-label="${wine.name} ${wine.vintage}">
            <div class="vortex-bg" aria-hidden="true"></div>
            ${discPct > 0 ? `<div class="discount-badge">−${discPct}% DESC.</div>` : ''}
            <div class="product-card__image-wrap">
              ${wine.imageUrl
                ? `<img src="${imageSrc}" alt="${wine.name} ${wine.vintage}" loading="lazy" onerror="this.onerror=null;this.src='${fallbackSrc}'">`
                : `<div class="product-card__image-placeholder">
                     <span style="font-size:3.5rem;filter:drop-shadow(0 0 20px rgba(212,175,55,0.5))">${icon}</span>
                   </div>`}
            </div>
            <div class="product-card__overlay">
              <div class="product-card__vintage">${wine.vintage}</div>
              <div class="product-card__name">${wine.name}</div>
              ${desc ? `<div class="product-card__desc">${desc}</div>` : ''}
              <div class="product-card__price-row">
                <span class="product-card__price">C$${finalPrice.toFixed(2)}</span>
                ${discPct > 0 ? `<span class="product-card__price-original">C$${wine.price.toFixed(2)}</span>` : ''}
                <span class="stock-indicator stock-indicator--${stockLevel}"
                      title="${window.BifrostDB.constructor.stockLabel(wine.stock)}"></span>
              </div>
            </div>
          </article>`;
      }).join('');
    }

    async function renderHomepageFeatured() {
      const grid = document.getElementById('featured-grid');
      if (!grid) return;

      try {
        const allWines = await window.BifrostDB.getAllWines();
        const selected = selectHomepageWines(allWines);
        const settings = await window.BifrostDB.getSettings() || {};
        grid.innerHTML = buildHomepageWineCards(selected, settings);

        window.reinitReveal?.();
        // Re-init 3D effects for newly rendered cards
        if (typeof initScrollDrift === 'function') initScrollDrift();
        if (typeof init3DTilt     === 'function') init3DTilt();
        if (typeof initFloatingFeatured === 'function') initFloatingFeatured();
      } catch (err) {
        console.error('Error al cargar vinos destacados:', err);
        const settings = await window.BifrostDB.getSettings().catch(() => ({})) || {};
        grid.innerHTML = buildHomepageWineCards(getHomepageFallbackWines(), settings);
      }
    }

    document.addEventListener('DOMContentLoaded', async () => {
      await window.BifrostDB.ready();
      await renderHomepageFeatured();
    });

    window.addEventListener('wines-updated', () => {
      renderHomepageFeatured().catch(err => console.warn('featured refresh error:', err));
    });
  </script>
