<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description"
    content="Bifrost S.A — La Colección Vortex Reserve. Vinos de cosecha premium elaborados con inspiración nórdica y raíces nicaragüenses. Chichigalpa, Nicaragua.">
  <meta name="keywords"
    content="vinos premium, Nicaragua, Chichigalpa, Vortex Reserve, vinos de lujo, colección especial">
  <meta name="theme-color" content="#0A0A0B">
  <meta property="og:title" content="Bifrost S.A — La Colección Vortex Reserve">
  <meta property="og:description"
    content="Donde el mito se encuentra con el viñedo. Vinos de cosecha premium desde Chichigalpa, Nicaragua.">
  <meta property="og:type" content="website">
  <title>Bifrost S.A — La Colección Vortex Reserve</title>

  <!-- ══ Hojas de estilo ══ -->
  <link rel="stylesheet" href="css/main.css">
  <link rel="stylesheet" href="css/effects.css">
  <link rel="stylesheet" href="css/components.css">

  <style>
    /* ── Variables de contacto / redes sociales ──────────────────
       Configura aquí los enlaces de cada plataforma.
       El equipo puede modificar estos valores libremente.
    ─────────────────────────────────────────────────────────────*/
    :root {
      --link-whatsapp: "https://wa.me/50576060334";
      /* Reemplazar con la URL real */
      --link-telegram: "https://t.me/Young_plague_FTP";
      /* Reemplazar con la URL real */
      --link-facebook: "https://facebook.com/bifrostwines";
      /* Reemplazar con la URL real */
      --link-instagram: "https://instagram.com/bifrostwines";
      /* Reemplazar con la URL real */
      --link-phone1: "tel:+50576060334";
      --link-phone2: "tel:+50588666717";
    }

    /* ── Hero ─────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero__bg-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.22;
      filter: saturate(0.7) brightness(0.8);
    }

    .hero__bg-gradient {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 30% 30%, rgba(212, 175, 55, 0.12) 0%, transparent 55%),
        radial-gradient(ellipse at 70% 70%, rgba(69, 162, 158, 0.09) 0%, transparent 55%),
        radial-gradient(ellipse at 50% 100%, rgba(10, 10, 11, 0.98) 0%, transparent 50%);
    }

    .hero__content {
      position: relative;
      z-index: 2;
      padding-top: var(--navbar-height);
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding-inline: var(--container-pad);
      padding-bottom: var(--space-20);
    }

    .hero__logo-img {
      width: clamp(180px, 28vw, 340px);
      height: auto;
      flex-shrink: 0;
      filter: drop-shadow(0 0 30px rgba(212, 175, 55, 0.3));
      animation: floatY 6s ease-in-out infinite;
    }

    .hero__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      font-size: var(--fs-xs);
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--color-gold);
      margin-bottom: var(--space-5);
    }

    .hero__eyebrow::before,
    .hero__eyebrow::after {
      content: '';
      width: 40px;
      height: 1px;
      background: var(--color-gold);
      opacity: 0.6;
      display: block;
    }

    .hero__title {
      font-family: var(--font-heading);
      font-size: var(--fs-hero);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -0.025em;
      color: var(--color-text-primary);
      margin-bottom: var(--space-3);
    }

    .hero__title-line2 {
      display: block;
      font-style: italic;
      font-weight: 400;
      font-size: 0.52em;
      color: var(--color-text-secondary);
      letter-spacing: 0.06em;
      margin-top: var(--space-3);
    }

    .hero__gold-line {
      width: 200px;
      height: 2px;
      background: var(--gradient-gold);
      margin: var(--space-6) auto;
      border-radius: var(--radius-full);
      animation: goldLine 1.2s var(--ease-silk) 0.8s both;
      box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
    }

    .hero__subtitle {
      font-size: var(--fs-md);
      color: var(--color-text-muted);
      max-width: 560px;
      line-height: 1.7;
      margin-bottom: var(--space-10);
    }

    .hero__cta-group {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
      justify-content: center;
    }

    /* ── Fila logo + botellas ────────────────────────────── */
    .hero__logo-row {
      display: flex;
      align-items: flex-end;
      /* botellas alineadas al pie del logo */
      justify-content: center;
      gap: 0;
      margin-bottom: var(--space-6);
      width: 100%;
      /* permite que las botellas sobresalgan sin afectar el layout del contenido */
      overflow: visible;
    }

    /* ── Hero Bottles (parallax, en flujo dentro de hero__logo-row) ── */
    .hero-bottle {
      width: clamp(220px, 28vw, 400px);
      height: auto;
      pointer-events: none;
      flex-shrink: 0;
      will-change: transform;
      filter:
        drop-shadow(0 20px 40px rgba(0, 0, 0, 0.65)) drop-shadow(0 0 24px rgba(212, 175, 55, 0.22));
    }

    .hero-bottle--left {
      transform: rotate(-12deg);
      margin-bottom: -10px;
      margin-right: -36px;
    }

    .hero-bottle--right {
      transform: rotate(12deg);
      margin-bottom: -10px;
      margin-left: -36px;
    }

    /* Tablet */
    @media (max-width: 1100px) {
      .hero-bottle {
        width: clamp(170px, 22vw, 280px);
      }
    }

    /* Móvil */
    @media (max-width: 768px) {
      .hero-bottle {
        width: clamp(130px, 28vw, 190px);
      }

      .hero-bottle--left {
        margin-right: -18px;
      }

      .hero-bottle--right {
        margin-left: -18px;
      }
    }

    @media (max-width: 420px) {
      .hero-bottle {
        width: clamp(105px, 26vw, 150px);
      }
    }

    @keyframes floatYCenter {

      0%,
      100% {
        transform: translate(-50%, 0);
      }

      50% {
        transform: translate(-50%, -10px);
      }
    }

    .hero__scroll-hint {
      position: absolute;
      bottom: var(--space-2);
      /* LOWERED the position significantly */
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-3);
      color: var(--color-text-muted);
      font-size: var(--fs-xs);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      z-index: 2;
      animation: floatYCenter 2s ease-in-out infinite;
    }

    .hero__scroll-hint span {
      margin-left: 0.15em;
      /* Compensate for the right letter-spacing to truly center visual text */
    }

    .hero__scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, var(--color-gold), transparent);
    }

    /* ── Featured Section ── */
    .featured-section {
      position: relative;
      padding-block: var(--space-20) var(--space-24);
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-12);
    }

    /* ── Story Section ── */
    .story-section {
      padding-block: var(--space-20);
      position: relative;
    }

    .story-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-20);
      align-items: center;
    }

    .story-visual {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .story-vineyard-img {
      width: 100%;
      border-radius: var(--radius-xl);
      border: 1px solid var(--color-glass-border);
      box-shadow: var(--shadow-card), var(--shadow-gold);
      filter: brightness(0.85) saturate(1.2);
      transition: transform var(--transition-slow);
    }

    .story-vineyard-img:hover {
      transform: scale(1.02);
    }

    .story-vineyard-badge {
      position: absolute;
      bottom: -16px;
      right: -16px;
      background: var(--gradient-gold);
      color: #000;
      font-family: var(--font-heading);
      font-size: var(--fs-xs);
      font-weight: 700;
      letter-spacing: 0.12em;
      padding: var(--space-3) var(--space-5);
      border-radius: var(--radius-md);
      text-transform: uppercase;
      box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);
    }

    .story-text {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .story-text h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
    }

    /* ── Brand Values ── */
    .values-section {
      padding-block: var(--space-16) var(--space-20);
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-5);
      margin-top: var(--space-12);
    }

    .value-card {
      padding: var(--space-6);
      border-radius: var(--radius-xl);
      text-align: center;
      transition: transform var(--transition-base);
    }

    .value-card:hover {
      transform: translateY(-4px);
    }

    .value-card__icon-img {
      width: 56px;
      height: 56px;
      margin: 0 auto var(--space-4);
      display: block;
      filter: sepia(1) saturate(3) hue-rotate(5deg) brightness(0.9);
      opacity: 0.85;
    }

    .value-card__icon-svg {
      width: 48px;
      height: 48px;
      margin: 0 auto var(--space-4);
      display: block;
      color: var(--color-gold);
      opacity: 0.75;
    }

    .value-card__title {
      font-family: var(--font-heading);
      font-size: var(--fs-md);
      font-weight: 700;
      margin-bottom: var(--space-2);
    }

    .value-card__desc {
      font-size: var(--fs-sm);
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    /* ── CTA Banner ── */
    .cta-banner {
      margin-block: var(--space-8) var(--space-20);
      padding: var(--space-16) var(--space-12);
      border-radius: var(--radius-xl);
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-banner::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.07) 0%, rgba(69, 162, 158, 0.05) 100%);
    }

    .cta-banner__content {
      position: relative;
      z-index: 1;
    }

    .cta-banner__title {
      font-family: var(--font-heading);
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      margin-bottom: var(--space-4);
    }

    /* ── Floating Contact Widget ──────────────────────────────── */
    .contact-widget {
      position: fixed;
      bottom: var(--space-8);
      left: var(--space-5);
      z-index: var(--z-dropdown);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      align-items: flex-start;
    }

    .contact-widget__toggle {
      width: 52px;
      height: 52px;
      border-radius: var(--radius-full);
      background: var(--gradient-gold);
      color: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(212, 175, 55, 0.5);
      transition: all var(--transition-base);
      border: none;
    }

    .contact-widget__toggle:hover {
      transform: scale(1.08);
      box-shadow: 0 8px 32px rgba(212, 175, 55, 0.6);
    }

    .contact-widget__toggle svg {
      width: 22px;
      height: 22px;
    }

    .contact-widget__menu {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      transition: all var(--transition-base);
      pointer-events: none;
    }

    .contact-widget__menu.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: all;
    }

    .contact-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-4) var(--space-2) var(--space-2);
      border-radius: var(--radius-full);
      font-size: var(--fs-xs);
      font-weight: 600;
      letter-spacing: 0.04em;
      text-decoration: none;
      transition: all var(--transition-base);
      white-space: nowrap;
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(10, 10, 18, 0.85);
      color: var(--color-text-primary);
    }

    .contact-btn:hover {
      transform: translateX(4px);
      border-color: var(--contact-color, var(--color-gold));
      box-shadow: 0 0 16px var(--contact-color, rgba(212, 175, 55, 0.3));
      color: var(--color-text-primary);
    }

    .contact-btn__icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-full);
      background: var(--contact-color, var(--color-gold));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-btn__icon svg {
      width: 18px;
      height: 18px;
      color: #fff;
    }

    /* Color per network */
    .contact-btn--whatsapp {
      --contact-color: #25D366;
    }

    .contact-btn--telegram {
      --contact-color: #2AABEE;
    }

    .contact-btn--facebook {
      --contact-color: #1877F2;
    }

    .contact-btn--instagram {
      --contact-color: #E1306C;
    }

    .contact-btn--phone {
      --contact-color: var(--color-gold);
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .values-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .story-inner {
        grid-template-columns: 1fr;
        gap: var(--space-10);
      }
    }

    @media (max-width: 768px) {
      .hero {
        min-height: auto;
        padding-top: var(--navbar-height);
      }

      .hero__content {
        padding-top: var(--space-8);
        padding-bottom: var(--space-16);
      }

      .hero__logo-row {
        margin-bottom: var(--space-5);
      }

      .hero__eyebrow {
        letter-spacing: 0.2em;
        gap: var(--space-2);
      }

      .hero__eyebrow::before,
      .hero__eyebrow::after {
        width: 24px;
      }

      .hero__subtitle {
        margin-bottom: var(--space-8);
      }

      .hero__cta-group {
        width: 100%;
      }

      .hero__cta-group .btn {
        width: min(100%, 360px);
      }

      .featured-grid {
        grid-template-columns: 1fr;
      }

      .story-vineyard-badge {
        right: 12px;
        bottom: 12px;
      }

      .cta-banner {
        padding: var(--space-12) var(--space-5);
      }

      .contact-widget {
        bottom: var(--space-6);
        left: var(--space-4);
      }
    }

    @media (max-width: 640px) {
      .hero__logo-img {
        width: clamp(140px, 42vw, 220px);
      }

      .hero__scroll-hint {
        display: none;
      }

      .story-text,
      .cta-banner__content {
        text-align: left;
      }

      .story-vineyard-badge {
        position: static;
        margin-top: var(--space-4);
        width: fit-content;
      }

      .contact-widget__menu {
        max-width: calc(100vw - 2rem);
      }

      .contact-btn {
        width: 100%;
      }

      .values-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <!-- Pantalla de Carga -->
  <div id="loading-screen">
    <img src="assets/images/ui/bifrost-logo.png" alt="Bifrost S.A" class="loader-logo"
      style="width:200px; height:auto; filter:drop-shadow(0 0 20px rgba(212,175,55,0.4));">
    <div class="loader-bar">
      <div class="loader-bar__fill"></div>
    </div>
  </div>

  <!-- Aurora de fondo -->
  <div class="aurora-bg" aria-hidden="true"></div>

  <!-- Telón de fondo (carrito, menú móvil) -->
  <div class="overlay-backdrop" aria-hidden="true"></div>

  <!-- ════════════════════════════════════════
       BARRA DE NAVEGACIÓN
  ════════════════════════════════════════ -->
  <header class="navbar" id="main-navbar">
    <div class="container navbar__inner">
      <!-- Logo -->
      <a href="index.html" class="navbar__logo" aria-label="Bifrost S.A — Inicio">
        <img src="assets/images/ui/bifrost-logo.png" alt="Bifrost S.A"
          style="height:44px; width:auto; filter:drop-shadow(0 0 12px rgba(212,175,55,0.3));">
      </a>

      <!-- Navegación escritorio -->
      <nav class="navbar__nav" aria-label="Navegación principal">
        <a href="index.html" class="navbar__link active">Inicio</a>
        <a href="statics/shop.html" class="navbar__link">Colección</a>
        <a href="statics/about.html" class="navbar__link">Nosotros</a>
        <a href="#contacto" class="navbar__link"
          onclick="document.querySelector('.contact-widget__toggle').click(); return false;">Contacto</a>
      </nav>

      <!-- Acciones -->
      <div class="navbar__actions">
        <button class="navbar__icon-btn" data-cart-toggle id="cart-toggle-btn" aria-label="Abrir carrito">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span class="cart-badge" id="cart-badge" aria-label="Artículos en el carrito"></span>
        </button>
        <button class="navbar__hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Menú Móvil -->
  <nav class="mobile-menu" id="mobile-menu" aria-label="Navegación móvil">
    <a href="index.html" class="mobile-menu__link">Inicio</a>
    <a href="statics/shop.html" class="mobile-menu__link">Colección</a>
    <a href="statics/about.html" class="mobile-menu__link">Nosotros</a>
    <a href="statics/about.html#contacto" class="mobile-menu__link">Contacto</a>
    <a href="statics/shop.html" class="btn btn--primary btn--lg" style="margin-top:1rem">Explorar Colección</a>
  </nav>

  <!-- ════════════════════════════════════════
       CARRITO LATERAL
  ════════════════════════════════════════ -->
  <aside class="cart-sidebar" id="cart-sidebar" aria-label="Carrito de compras">
    <div class="cart-sidebar__header">
      <h2 class="cart-sidebar__title">Tu Cava</h2>
      <button class="cart-sidebar__close" id="cart-close" aria-label="Cerrar carrito">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="cart-sidebar__items" id="cart-items"></div>
    <div class="cart-sidebar__footer">
      <div class="cart-total-row">
        <span class="cart-total-label">Subtotal</span>
        <span class="cart-total-value" id="cart-total">$0.00</span>
      </div>
      <button class="btn btn--primary btn--lg btn-ripple" style="width:100%" data-checkout id="checkout-btn">
        Enviar Consulta
      </button>
      <p style="font-size:0.7rem; color:var(--color-text-muted); text-align:center; margin-top:12px;">
        Envío internacional gratuito en pedidos superiores a $500
      </p>
    </div>
  </aside>

  <!-- ════════════════════════════════════════
       SECCIÓN HÉROE
  ════════════════════════════════════════ -->
  <main>
    <section class="hero scene-3d section-camera" id="hero" aria-label="Héroe principal" data-camera-section
      data-camera-intensity="1.15">
      <!-- Fondo -->
      <div class="hero__bg" aria-hidden="true">
        <img src="assets/images/bg/hero-vortex.png" alt="" class="hero__bg-img" role="presentation">
        <div class="hero__nebula-grid"></div>
        <div class="vortex-orb vortex-orb--gold"></div>
        <div class="vortex-orb vortex-orb--frost"></div>
        <div class="vortex-orb vortex-orb--purple"></div>
        <div class="morph-blob morph-blob--hero-a"></div>
        <div class="morph-blob morph-blob--hero-b"></div>
        <div class="morph-ring morph-ring--hero"></div>
        <div class="hero__bg-gradient"></div>
        <div class="particles-layer" data-count="18" aria-hidden="true"></div>
      </div>

      <!-- Contenido -->
      <div class="hero__content" data-depth="0.16">
        <!-- Fila: botella izquierda | logo | botella derecha -->
        <div class="hero__logo-row hero-animate">
          <img id="hero-bottle-left" src="assets/images/wines/bottles-1.png" alt="" aria-hidden="true"
            class="hero-bottle hero-bottle--left" data-depth="0.28">
          <img src="assets/images/ui/bifrost-logo.png" alt="Bifrost S.A — Vortex Reserve" class="hero__logo-img"
            data-depth="0.34">
          <img id="hero-bottle-right" src="assets/images/wines/bottles-2.png" alt="" aria-hidden="true"
            class="hero-bottle hero-bottle--right" data-depth="0.28">
        </div>

        <p class="hero__eyebrow hero-animate" data-depth="0.1">La Colección Vortex Reserve</p>

        <h1 class="hero__title hero-animate" data-depth="0.22">
          BIFROST WINES
          <span class="hero__title-line2">
            Donde el Mito se Encuentra con el Viñedo
          </span>
        </h1>

