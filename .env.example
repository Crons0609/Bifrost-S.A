PORT=3000

# ── TELEGRAM BOT CONFIGURATION ──
# Consigue tu Bot Token hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN="TU_TOKEN_AQUI"

# El ID de tu cuenta personal de Telegram para que el bot solo te obedezca a ti.
# Puedes saber tu ID hablando con el bot @userinfobot en Telegram.
ADMIN_TELEGRAM_ID="TU_ID_AQUI"

# ── CONFIGURACIÓN FIREBASE ──
# Obtén esto de tu consola de Firebase (ej. https://mi-proyecto.firebaseio.com)
FIREBASE_DATABASE_URL="TU_FIREBASE_URL"
